DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=commit
JWT_SECRET=your-secret-here
PORT=8080
APP_ENV=development
JWT_EXPIRY_HOURS=168
FOCUS_DAILY_MINIMUM_MINUTES=120
LOGIN_RATE_LIMIT=5
DB_MAX_CONNS=10
DB_MIN_CONNS=1
DB_MAX_CONN_LIFETIME_MINUTES=60
DB_MAX_CONN_IDLE_MINUTES=30

# Comma-separated list of origins allowed to make cross-origin requests
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Refresh token expiry in minutes (default: 1440)
JWT_EXPIRY_MINUTES=1440

# Frontend URL — used for password reset links; same as VITE_WEB_URL
VITE_WEB_URL=http://localhost:5173

# Email (password reset via Resend) — optional; falls back to console logging when empty
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com
